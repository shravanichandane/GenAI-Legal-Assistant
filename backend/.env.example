# ────────────────────────────────────────────────
# Legal Assistant — Environment Variables
# ────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
#   cp .env.example .env
#
# ⚠️  NEVER commit .env to source control.
# ────────────────────────────────────────────────

# Google Gemini AI (required)
GOOGLE_API_KEY=your_google_api_key_here

# PostgreSQL Database (required for production)
# For local dev, leave unset to use SQLite fallback
DATABASE_URL=postgresql://user:password@localhost:5432/legal_assistant

# JWT Authentication
JWT_SECRET_KEY=CHANGE_ME_generate_a_random_64_char_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
